@model TuristickaAgencija.Mvc.Models.Aranzman

@{
    ViewData["Title"] = "Dodaj aranžman";
}

<h1>Dodaj aranžman</h1>

<h4>Aranžman</h4>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <partial name="_AranzmanFormPartial" model="Model" />

            <div class="form-group mt-3">
                <input type="submit" value="Spremi" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Nazad</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}